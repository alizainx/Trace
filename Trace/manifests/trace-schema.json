{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "trace Output Schema",
  "description": "JSON schema for trace system call tracing tool output",
  "type": "object",
  "properties": {
    "process": {
      "type": "object",
      "description": "Process information",
      "properties": {
        "pid": {
          "type": "integer",
          "description": "Process ID",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "description": "Process name"
        },
        "status": {
          "type": "string",
          "description": "Process status",
          "enum": ["Running", "Sleeping", "Stopped", "Zombie"]
        },
        "memory_mb": {
          "type": "integer",
          "description": "Memory usage in MB",
          "minimum": 0
        },
        "cpu_percent": {
          "type": "number",
          "description": "CPU usage percentage",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": ["pid", "name", "status", "memory_mb", "cpu_percent"]
    },
    "syscalls": {
      "type": "object",
      "description": "System call statistics",
      "properties": {
        "total": {
          "type": "integer",
          "description": "Total number of syscalls",
          "minimum": 0
        },
        "unique": {
          "type": "integer",
          "description": "Number of unique syscalls",
          "minimum": 0
        },
        "top": {
          "type": "array",
          "description": "Top syscalls by frequency",
          "items": {
            "type": "string"
          },
          "minItems": 0,
          "maxItems": 10
        },
        "detailed": {
          "type": "array",
          "description": "Detailed syscall statistics",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Syscall name"
              },
              "count": {
                "type": "integer",
                "description": "Number of invocations",
                "minimum": 0
              },
              "bytes": {
                "type": "integer",
                "description": "Bytes transferred",
                "minimum": 0
              }
            },
            "required": ["name", "count", "bytes"]
          }
        }
      },
      "required": ["total", "unique", "top"]
    },
    "network": {
      "type": "object",
      "description": "Network activity statistics",
      "properties": {
        "active_connections": {
          "type": "integer",
          "description": "Number of active connections",
          "minimum": 0
        },
        "bytes_sent": {
          "type": "integer",
          "description": "Total bytes sent",
          "minimum": 0
        },
        "bytes_received": {
          "type": "integer",
          "description": "Total bytes received",
          "minimum": 0
        }
      },
      "required": ["active_connections", "bytes_sent", "bytes_received"]
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of trace execution",
      "format": "date-time"
    }
  },
  "required": ["process", "syscalls", "network", "timestamp"],
  "additionalProperties": false,
  "examples": [
    {
      "process": {
        "pid": 3245,
        "name": "firefox",
        "status": "Running",
        "memory_mb": 842,
        "cpu_percent": 14.8
      },
      "syscalls": {
        "total": 1847,
        "unique": 42,
        "top": ["read", "write", "poll"],
        "detailed": [
          {
            "name": "read",
            "count": 412,
            "bytes": 2048000
          },
          {
            "name": "write",
            "count": 289,
            "bytes": 1024000
          }
        ]
      },
      "network": {
        "active_connections": 12,
        "bytes_sent": 4194304,
        "bytes_received": 19660800
      },
      "timestamp": "2025-04-05T12:45:33+00:00"
    }
  ]
}
